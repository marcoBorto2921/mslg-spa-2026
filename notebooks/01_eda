    "# Analyze special annotations\n",
    "import re\n",
    "\n",
    "def count_annotation(df, pattern, name):\n",
    "    count = df['mslg'].str.contains(pattern, regex=True).sum()\n",
    "    examples = df[df['mslg'].str.contains(pattern, regex=True)]['mslg'].head(3).tolist()\n",
    "    print(f\"\\n{name}: {count} occurrences ({count/len(df)*100:.1f}%)\")\n",
    "    for ex in examples:\n",
    "        print(f\"  → {ex}\")\n",
    "\n",
    "count_annotation(df, r'-', 'Hyphen (-)')\n",
    "count_annotation(df, r'\\+', 'Plus (+)')\n",
    "count_annotation(df, r'#', 'Number sign (#)')\n",
    "count_annotation(df, r'dm-', 'Fingerspelling (dm-)')"
   ]
